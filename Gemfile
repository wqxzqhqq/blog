source "https://rubygems.org"

# 使用 Minimal Mistakes 主题
gem "minimal-mistakes-jekyll"

# 添加 GitHub Pages 支持
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
end

# Windows 平台需要
platforms :windows do
  gem "tzinfo"
  gem "tzinfo-data"
  # gem "wdm", "~> 0.1.1"
end
